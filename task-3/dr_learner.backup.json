    {
      "parameters": {
        "jsCode": "// Parse Teacher AI response\nconst aiOutput = $input.first().json.output;\nconst previousData = $('Learn_GetMaterials_Parse').first().json;\n\n// Extract the text from OpenAI response structure\nlet aiText = '';\nif (Array.isArray(aiOutput) && aiOutput[0]?.content?.[0]?.text) {\n  aiText = aiOutput[0].content[0].text;\n} else {\n  aiText = $input.first().json.message?.content || $input.first().json.text || '';\n}\n\nlet summary;\ntry {\n  // Remove markdown code blocks if present\n  let jsonText = aiText.trim();\n  \n  // Check if wrapped in ```json ... ```\n  if (jsonText.startsWith('```json')) {\n    jsonText = jsonText.replace(/^```json\\s*\\n/, '').replace(/\\n```$/, '');\n  } else if (jsonText.startsWith('```')) {\n    jsonText = jsonText.replace(/^```\\s*\\n/, '').replace(/\\n```$/, '');\n  }\n  \n  // Parse the cleaned JSON\n  summary = JSON.parse(jsonText.trim());\n  \n} catch (error) {\n  // Fallback if parsing fails\n  console.error('JSON parse error:', error);\n  summary = {\n    title: previousData.title,\n    overview: \"Summary generation failed. Please try again.\",\n    keyPoints: [],\n    mainConcepts: [],\n    difficulty: \"unknown\",\n    estimatedReadingTime: \"N/A\"\n  };\n}\n\n// Generate unique ID for this material\nconst timestamp = Date.now();\nconst materialId = `LM-${timestamp}`;\n\n// Prepare complete learning material object\nreturn {\n  json: {\n    // Metadata\n    id: materialId,\n    userId: previousData.userId,\n    chatId: previousData.chatId,\n    url: previousData.url,\n    addedDate: new Date().toISOString(),\n    \n    // Content\n    title: summary.title || previousData.title,\n    content: previousData.content,\n    \n    // AI-generated summary\n    summary: {\n      overview: summary.overview,\n      keyPoints: summary.keyPoints || [],\n      mainConcepts: summary.mainConcepts || [],\n      difficulty: summary.difficulty || \"intermediate\",\n      estimatedReadingTime: summary.estimatedReadingTime || \"5 minutes\"\n    }\n  }\n};"
      },
