    {
      "parameters": {
        "jsCode": "const materials = $input.all();\nconst chatId = $('Telegram Trigger').first().json.message.chat.id;\n\nconst count = materials.length;\n\nconst keyboard = [];\n\nmaterials.forEach(item => {\n  const data = item.json;\n  \n  let difficulty = '⚪';\n  try {\n    const summary = typeof data.summaryJSON === 'string' \n      ? JSON.parse(data.summaryJSON) \n      : data.summary;\n    \n    const emojiMap = {\n      'beginner': '🟢',\n      'intermediate': '🟡',\n      'advanced': '🔴'\n    };\n    difficulty = emojiMap[summary.difficulty] || '⚪';\n  } catch (e) {}\n  \n  keyboard.push([{\n    text: `${difficulty} ${data.title}`,\n    callback_data: `quiz_${data.id}`\n  }]);\n});\n\nkeyboard.push([{\n  text: \"❌ Cancel\",\n  callback_data: \"quiz_cancel\"\n}]);\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    text: `📚 Select a material to quiz on:\\n\\nYou have ${count} saved material(s).`,\n    reply_markup: {\n      inline_keyboard: keyboard\n    }\n  }\n}];"
      },
