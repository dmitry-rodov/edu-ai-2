    {
      "parameters": {
        "jsCode": "// Format summary for Telegram display\nconst data = $input.first().json;\nconst summary = typeof data.summaryJSON === 'string' \n  ? JSON.parse(data.summaryJSON) \n  : data.summary;\n\n// Build formatted message with Telegram Markdown\nlet message = `📚 *Learning Material Saved*\\n\\n`;\nmessage += `*${data.title}*\\n\\n`;\n\n// Overview\nmessage += `📝 *Overview:*\\n${summary.overview}\\n\\n`;\n\n// Difficulty badge\nconst difficultyEmoji = {\n  'beginner': '🟢',\n  'intermediate': '🟡',\n  'advanced': '🔴'\n};\nmessage += `${difficultyEmoji[summary.difficulty] || '⚪'} Difficulty: *${summary.difficulty}*\\n`;\nmessage += `⏱ Reading time: ${summary.estimatedReadingTime}\\n\\n`;\n\n// Key Points\nmessage += `🎯 *Key Points:*\\n`;\nsummary.keyPoints.forEach((point, index) => {\n  message += `${index + 1}. ${point}\\n`;\n});\nmessage += `\\n`;\n\n// Main Concepts\nmessage += `💡 *Main Concepts:*\\n`;\nsummary.mainConcepts.forEach((concept, index) => {\n  message += `• ${concept}\\n`;\n});\nmessage += `\\n`;\n\n// Footer\nmessage += `✅ Material saved! Use /quiz to test your knowledge.\\n`;\nmessage += `📎 ID: \\`${data.id}\\``;\n\nreturn {\n  json: {\n    chatId: data.chatId,\n    message: message,\n    materialId: data.id\n  }\n};"
      },
