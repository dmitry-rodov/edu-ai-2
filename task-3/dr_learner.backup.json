      "parameters": {
        "jsCode": "// Extract URL from /learn command\nconst messageText = $input.first().json.message.text;\nconst chatId = $input.first().json.message.chat.id;\nconst userId = $input.first().json.message.from.id;\n\n// Split the message: \"/learn https://example.com\"\nconst parts = messageText.trim().split(/\\s+/);\n\n// Check if URL was provided\nif (parts.length < 2) {\n  return {\n    json: {\n      error: true,\n      chatId: chatId,\n      errorMessage: \"❌ Please provide a URL.\\n\\nUsage: /learn [url]\\nExample: /learn https://example.com/article\"\n    }\n  };\n}\n\nconst url = parts[1];\n\n// Basic URL validation\nconst urlPattern = /^https?:\\/\\/.+/i;\nif (!urlPattern.test(url)) {\n  return {\n    json: {\n      error: true,\n      chatId: chatId,\n      errorMessage: \"❌ Invalid URL format.\\n\\nPlease provide a valid URL starting with http:// or https://\"\n    }\n  };\n}\n\n// Success - return extracted data\nreturn {\n  json: {\n    error: false,\n    chatId: chatId,\n    userId: userId,\n    url: url,\n    originalMessage: messageText\n  }\n};"
      },
