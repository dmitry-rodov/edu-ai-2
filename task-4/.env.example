# Required
RUNWAY_COUNT=2
GATE_COUNT=4
GROUND_CREW_COUNT=3

# Runway separation buffers (minutes)
RUNWAY_SEPARATION_TAKEOFF=2
RUNWAY_SEPARATION_LANDING=3
RUNWAY_SEPARATION_MIXED=4

# Timing (minutes)
GATE_TURNAROUND_TIME=30
DEPENDENCY_BUFFER_TIME=15
MAX_SCHEDULING_HORIZON=480

# Optional: comma-separated runway lengths in meters (defaults to 3000m each)
# Must have exactly RUNWAY_COUNT values if set
# RUNWAY_LENGTHS=3000,2500

# Optional: operation durations in minutes (defaults: arrival=15, departure=20)
# ARRIVAL_DURATION=15
# DEPARTURE_DURATION=20
